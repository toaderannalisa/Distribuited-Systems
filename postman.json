              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"username\": \"johndoe\",\n  \"password\": \"password123\",\n  \"address\": \"123 Main Street, Cluj-Napoca\",\n  \"age\": 25,\n  \"role\": \"CLIENT\"\n}"
